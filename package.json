  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.35.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.2",
    "vite-ssr-components": "^0.6.1",
    "wrangler": "^4.87.0"
  }
}
